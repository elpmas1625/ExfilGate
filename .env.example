AICF_CONFIG=examples/config.yaml
AICF_AUDIT_PATH=./data/audit.jsonl

# Required for the default DeepSeek provider in examples/config.yaml.
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key

# Optional override for local testing or another OpenAI-compatible provider.
# AICF_PROVIDER_BASE_URL=http://127.0.0.1:18080/v1

# Optional generic provider key fallback.
# AICF_PROVIDER_API_KEY=replace_with_provider_api_key
